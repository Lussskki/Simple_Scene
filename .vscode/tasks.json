{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "C:/msys64/ucrt64/bin/g++.exe -std=c++17 src/*.cpp src/glad.c -Iinclude -Llib -lglfw3 -lopengl32 -lgdi32 -o scene.exe",
      "options": {
        "env": {
          "PATH": "C:/msys64/ucrt64/bin;${env:PATH}"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "run",
      "type": "shell",
      "command": "scene.exe",
      "dependsOn": "build"
    }
  ]
}
