{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "g++ -std=c++17 src/*.cpp -Iinclude -Llib -lglfw3 -lopengl32 -lgdi32 -lopengl32 -o scene.exe",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "run",
      "type": "shell",
      "command": "scene.exe",
      "dependsOn": "build"
    }
  ]
}
